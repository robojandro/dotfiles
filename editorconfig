# top-most EditorConfig file
root = true

# Unix-style newlines with a newline character at the end of each file
[*]
end_of_line = lf
insert_final_newline = true

# 4 space indentation for all .js and .py files
[*.{js,json,py}]
indent_style = space
indent_size = 2

# 4 space indentation for all .js and .py files
[*.{go}]
indent_style = space
indent_size = 4

